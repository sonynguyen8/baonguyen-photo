---
import { EmDashHead, EmDashBodyStart, EmDashBodyEnd } from "emdash/ui";
import { createPublicPageContext } from "emdash/page";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/theme.css";

interface Props {
	title: string;
	description?: string | null;
	image?: string | null;
	canonical?: string | null;
	robots?: string | null;
	type?: "website" | "article";
	publishedTime?: string | null;
	modifiedTime?: string | null;
	author?: string | null;
	/** Pass content reference for plugin page contributions on content pages */
	content?: { collection: string; id: string; slug?: string | null };
}

const {
	title,
	description,
	image,
	canonical,
	robots,
	type = "website",
	publishedTime,
	modifiedTime,
	author,
	content,
} = Astro.props;

const siteTitle = "Bao Nguyen Studio";
const fullTitle = title.includes(siteTitle) ? title : `${title} — ${siteTitle}`;

const pageCtx = createPublicPageContext({
	Astro,
	kind: content ? "content" : "custom",
	pageType: type,
	title: fullTitle,
	description,
	canonical,
	image,
	content,
	seo: { ogImage: image, robots },
	articleMeta: { publishedTime, modifiedTime, author },
	siteName: siteTitle,
});
---

<!doctype html>
<html lang="en" class="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Newsreader:ital,wght@0,200..800;1,200..800&family=Manrope:wght@200..800&display=swap"
			rel="stylesheet"
		/>
		<link
			href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
			rel="stylesheet"
		/>
		<title>{fullTitle}</title>
		<EmDashHead page={pageCtx} />
	</head>
	<body>
		<EmDashBodyStart page={pageCtx} />

		<!-- Page transition overlay -->
		<div class="page-transition" id="page-transition" aria-hidden="true"></div>

		<!-- Cinematic scroll indicator -->
		<div class="cinematic-scrubber" id="scroll-indicator" aria-hidden="true"></div>

		<Header />

		<main>
			<slot />
		</main>

		<Footer />

		<EmDashBodyEnd page={pageCtx} />

		<script>
			// Page transition
			const overlay = document.getElementById("page-transition");
			if (overlay) {
				// Fade out on enter
				overlay.classList.add("pt-enter");
				requestAnimationFrame(() => {
					requestAnimationFrame(() => overlay.classList.add("pt-visible"));
				});

				// Intercept all same-origin link clicks
				document.addEventListener("click", (e) => {
					const a = (e.target as Element).closest("a");
					if (!a) return;
					const href = a.getAttribute("href");
					if (!href || href.startsWith("#") || href.startsWith("mailto") || href.startsWith("tel")) return;
					try {
						const url = new URL(href, location.href);
						if (url.origin !== location.origin) return;
					} catch { return; }
					if (a.target === "_blank") return;

					e.preventDefault();
					const dest = a.href;
					overlay.classList.remove("pt-visible");
					overlay.addEventListener("transitionend", () => {
						location.href = dest;
					}, { once: true });
				});
			}
		</script>

		<script>
			// Cinematic scrubber — tracks scroll depth
			const indicator = document.getElementById("scroll-indicator");
			if (indicator) {
				window.addEventListener("scroll", () => {
					const scrollTop = window.scrollY;
					const docHeight = document.documentElement.scrollHeight - window.innerHeight;
					const pct = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
					indicator.style.width = `${pct}%`;
				}, { passive: true });
			}

			// Image skeleton — fade in images when loaded, remove shimmer
			const SK_SELECTOR = '.ic, .gallery-img-wrap, .about-image-wrap, .service-img-wrap, .hero-image-wrap, .hero-bg, .cta-bg';
			document.querySelectorAll<HTMLElement>(SK_SELECTOR).forEach(wrap => {
				const img = wrap.querySelector('img');
				if (!img) return;

				img.style.opacity = '0';
				img.style.transition = 'opacity 0.6s ease';

				const reveal = () => {
					img.style.opacity = '1';
					wrap.classList.add('sk-loaded');
				};

				if ((img as HTMLImageElement).complete && (img as HTMLImageElement).naturalWidth > 0) {
					reveal();
				} else {
					img.addEventListener('load', reveal, { once: true });
					img.addEventListener('error', reveal, { once: true });
				}
			});
		</script>

		<style is:global>
			/* ─── Reset ─────────────────────────────────── */
			*,
			*::before,
			*::after {
				box-sizing: border-box;
			}

			body,
			h1, h2, h3, h4, h5, h6,
			p, ul, ol, figure, blockquote, dl, dd {
				margin: 0;
			}

			ul, ol {
				padding: 0;
				list-style: none;
			}

			img {
				max-width: 100%;
				height: auto;
				display: block;
			}

			/* ─── Design Tokens ──────────────────────────── */
			:root {
				/* Typography */
				--font-headline: "Newsreader", Georgia, serif;
				--font-body: "Manrope", system-ui, sans-serif;

				/* Cinematic palette */
				--color-background:                #131313;
				--color-surface:                   #131313;
				--color-surface-dim:               #131313;
				--color-surface-container-lowest:  #0e0e0e;
				--color-surface-container-low:     #1b1b1b;
				--color-surface-container:         #1f1f1f;
				--color-surface-container-high:    #2a2a2a;
				--color-surface-container-highest: #353535;
				--color-surface-bright:            #393939;
				--color-on-surface:                #e2e2e2;
				--color-on-surface-variant:        #c6c6c6;
				--color-primary:                   #ffffff;
				--color-on-primary:                #1a1c1c;
				--color-primary-container:         #d4d4d4;
				--color-outline:                   #919191;
				--color-outline-variant:           #474747;

				/* Layout */
				--max-width: 1536px;

				/* Transitions */
				--ease-cinematic: cubic-bezier(0.16, 1, 0.3, 1);
			}

			/* ─── Base Styles ────────────────────────────── */
			html {
				scroll-behavior: smooth;
			}

			body {
				font-family: var(--font-body);
				background-color: var(--color-background);
				color: var(--color-on-surface);
				-webkit-font-smoothing: antialiased;
				-moz-osx-font-smoothing: grayscale;
				min-height: 100vh;
			}

			a {
				color: inherit;
				text-decoration: none;
			}

			::selection {
				background: var(--color-primary);
				color: var(--color-on-primary);
			}

			/* Material icons weight */
			.material-symbols-outlined {
				font-variation-settings: "FILL" 0, "wght" 200, "GRAD" 0, "opsz" 24;
			}

			/* ─── Page Transition Overlay ───────────────── */
			.page-transition {
				position: fixed;
				inset: 0;
				z-index: 9999;
				background: var(--color-background);
				opacity: 1;
				pointer-events: none;
				transition: opacity 0.55s cubic-bezier(0.16, 1, 0.3, 1);
			}

			.page-transition.pt-enter {
				opacity: 1;
			}

			.page-transition.pt-visible {
				opacity: 0;
			}

			/* ─── Cinematic Scrubber ─────────────────────── */
			.cinematic-scrubber {
				position: fixed;
				top: 0;
				left: 0;
				height: 1px;
				width: 0%;
				background: var(--color-primary);
				z-index: 100;
				transition: width 0.1s linear;
			}

			/* ─── Universal Image Hover ─────────────────── */
			.ic img,
			.gallery-img-wrap img,
			.about-image-wrap img,
			.hero-image-wrap img,
			.s8 img {
				transition:
					transform 0.9s cubic-bezier(0.16, 1, 0.3, 1),
					filter 0.9s ease !important;
			}

			.ic:hover img,
			.gallery-img-wrap:hover img,
			.about-image-wrap:hover img,
			.hero-image-wrap:hover img,
			.s8 img:hover {
				transform: scale(1.07) !important;
				filter: grayscale(0) !important;
			}

			/* ─── Image Skeleton Loading ─────────────────── */
			@keyframes sk-shimmer {
				0%   { background-position: 200% 0; }
				100% { background-position: -200% 0; }
			}

			.ic,
			.gallery-img-wrap,
			.about-image-wrap,
			.service-img-wrap,
			.hero-image-wrap,
			.hero-bg,
			.cta-bg {
				position: relative;
			}

			.ic::before,
			.gallery-img-wrap::before,
			.about-image-wrap::before,
			.service-img-wrap::before,
			.hero-image-wrap::before,
			.hero-bg::before,
			.cta-bg::before {
				content: '';
				position: absolute;
				inset: 0;
				z-index: 2;
				pointer-events: none;
				background: linear-gradient(
					90deg,
					transparent 25%,
					rgba(255, 255, 255, 0.055) 50%,
					transparent 75%
				);
				background-size: 200% 100%;
				animation: sk-shimmer 1.6s ease-in-out infinite;
				transition: opacity 0.5s ease;
			}

			.sk-loaded::before {
				opacity: 0;
				animation: none;
			}
		</style>
	</body>
</html>
