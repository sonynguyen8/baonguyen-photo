---
import { EmDashHead, EmDashBodyStart, EmDashBodyEnd } from "emdash/ui";
import { createPublicPageContext } from "emdash/page";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/theme.css";

interface Props {
	title: string;
	description?: string | null;
	image?: string | null;
	canonical?: string | null;
	robots?: string | null;
	type?: "website" | "article";
	publishedTime?: string | null;
	modifiedTime?: string | null;
	author?: string | null;
	/** Pass content reference for plugin page contributions on content pages */
	content?: { collection: string; id: string; slug?: string | null };
}

const {
	title,
	description,
	image,
	canonical,
	robots,
	type = "website",
	publishedTime,
	modifiedTime,
	author,
	content,
} = Astro.props;

const siteTitle = "Bao Nguyen Studio";
const fullTitle = title.includes(siteTitle) ? title : `${title} — ${siteTitle}`;

const pageCtx = createPublicPageContext({
	Astro,
	kind: content ? "content" : "custom",
	pageType: type,
	title: fullTitle,
	description,
	canonical,
	image,
	content,
	seo: { ogImage: image, robots },
	articleMeta: { publishedTime, modifiedTime, author },
	siteName: siteTitle,
});
---

<!doctype html>
<html lang="en" class="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Newsreader:ital,wght@0,200..800;1,200..800&family=Manrope:wght@200..800&display=swap"
			rel="stylesheet"
		/>
		<link
			href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
			rel="stylesheet"
		/>
		<title>{fullTitle}</title>
		<EmDashHead page={pageCtx} />
	</head>
	<body>
		<EmDashBodyStart page={pageCtx} />

		<!-- Cinematic scroll indicator -->
		<div class="cinematic-scrubber" id="scroll-indicator" aria-hidden="true"></div>

		<Header />

		<main>
			<slot />
		</main>

		<Footer />

		<EmDashBodyEnd page={pageCtx} />

		<script>
			// Cinematic scrubber — tracks scroll depth
			const indicator = document.getElementById("scroll-indicator");
			if (indicator) {
				window.addEventListener("scroll", () => {
					const scrollTop = window.scrollY;
					const docHeight = document.documentElement.scrollHeight - window.innerHeight;
					const pct = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
					indicator.style.width = `${pct}%`;
				}, { passive: true });
			}
		</script>

		<style is:global>
			/* ─── Reset ─────────────────────────────────── */
			*,
			*::before,
			*::after {
				box-sizing: border-box;
			}

			body,
			h1, h2, h3, h4, h5, h6,
			p, ul, ol, figure, blockquote, dl, dd {
				margin: 0;
			}

			ul, ol {
				padding: 0;
				list-style: none;
			}

			img {
				max-width: 100%;
				height: auto;
				display: block;
			}

			/* ─── Design Tokens ──────────────────────────── */
			:root {
				/* Typography */
				--font-headline: "Newsreader", Georgia, serif;
				--font-body: "Manrope", system-ui, sans-serif;

				/* Cinematic palette */
				--color-background:                #131313;
				--color-surface:                   #131313;
				--color-surface-dim:               #131313;
				--color-surface-container-lowest:  #0e0e0e;
				--color-surface-container-low:     #1b1b1b;
				--color-surface-container:         #1f1f1f;
				--color-surface-container-high:    #2a2a2a;
				--color-surface-container-highest: #353535;
				--color-surface-bright:            #393939;
				--color-on-surface:                #e2e2e2;
				--color-on-surface-variant:        #c6c6c6;
				--color-primary:                   #ffffff;
				--color-on-primary:                #1a1c1c;
				--color-primary-container:         #d4d4d4;
				--color-outline:                   #919191;
				--color-outline-variant:           #474747;

				/* Layout */
				--max-width: 1536px;

				/* Transitions */
				--ease-cinematic: cubic-bezier(0.16, 1, 0.3, 1);
			}

			/* ─── Base Styles ────────────────────────────── */
			html {
				scroll-behavior: smooth;
			}

			body {
				font-family: var(--font-body);
				background-color: var(--color-background);
				color: var(--color-on-surface);
				-webkit-font-smoothing: antialiased;
				-moz-osx-font-smoothing: grayscale;
				min-height: 100vh;
			}

			a {
				color: inherit;
				text-decoration: none;
			}

			::selection {
				background: var(--color-primary);
				color: var(--color-on-primary);
			}

			/* Material icons weight */
			.material-symbols-outlined {
				font-variation-settings: "FILL" 0, "wght" 200, "GRAD" 0, "opsz" 24;
			}

			/* ─── Cinematic Scrubber ─────────────────────── */
			.cinematic-scrubber {
				position: fixed;
				top: 0;
				left: 0;
				height: 1px;
				width: 0%;
				background: var(--color-primary);
				z-index: 100;
				transition: width 0.1s linear;
			}
		</style>
	</body>
</html>
