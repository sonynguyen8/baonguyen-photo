---
import Base from "../layouts/Base.astro";
import { Image } from "astro:assets";
---

<Base title="Bao Nguyen Studio" description="Cinematic noir photography — preserving the silent poetry of your most intimate moments.">

	<!-- ─── Hero ─────────────────────────────────────────── -->
	<section class="hero">
		<div class="hero-bg">
			<Image
				src="/images/home/hero-banner.jpg"
				alt="Couple standing by the river with Ho Chi Minh City skyline"
				class="hero-img"
				width={1920}
				height={1080}
				widths={[640, 1280, 1920]}
				sizes="100vw"
				loading="eager"
				layout="none"
			/>
		</div>
		<div class="hero-content">
			<h1 class="hero-title">
				Preserving the silent poetry of your most intimate moments.
			</h1>
			<p class="hero-sub">Cinematic Noir Photography</p>
		</div>
		<div class="hero-scrubber-deco" aria-hidden="true"></div>
	</section>

	<!-- ─── About ────────────────────────────────────────── -->
	<section class="about">
		<div class="about-inner">
			<div class="about-image-col">
				<div class="about-image-wrap">
					<Image
						src="/images/home/photo-profile.jpg"
						alt="Portrait of Bao Nguyen"
						class="about-img"
						width={800}
						height={1067}
						widths={[400, 800]}
						sizes="(max-width: 768px) 100vw, 40vw"
						layout="none"
					/>
				</div>
				<p class="about-caption">The Artist · 2024</p>
			</div>

			<div class="about-text-col">
				<span class="about-eyebrow">A Note from Bao</span>
				<h2 class="about-heading">
					I don't just capture images. I document the atmosphere of existence.
				</h2>
				<div class="about-body">
					<p>
						My approach is rooted in the philosophy of the cinematic
						negative—finding beauty in the shadows, and depth in the unspoken.
						Based in the heart of the city, I travel worldwide to capture love
						in its rawest, most unposed form.
					</p>
					<p>
						Every frame is a curated memory, treated with the same reverence as
						a piece of gallery art. We aren't just making photos; we are
						building your legacy.
					</p>
				</div>
				<a href="/about" class="about-cta">
					<span>Read the Manifesto</span>
					<span class="material-symbols-outlined about-cta-arrow">arrow_forward</span>
				</a>
			</div>
		</div>
	</section>

	<!-- ─── Services ─────────────────────────────────────── -->
	<section class="services">
		<div class="services-inner">
			<div class="services-header">
				<h2 class="services-heading">What I Do</h2>
				<p class="services-sub">Tailored Editorial Experiences</p>
			</div>

			<div class="services-grid">
				<!-- Portraits -->
				<article class="service-card">
					<div class="service-img-wrap">
						<Image
							src="/images/home/what-i-do-3.jpg"
							alt="Bride in garden with flowers"
							class="service-img"
							width={800}
							height={1000}
							widths={[400, 800]}
							sizes="(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 33vw"
							layout="none"
						/>
					</div>
					<h3 class="service-title">Portraits</h3>
					<p class="service-desc">
						Personal legacies captured with an editorial lens. Focused on
						identity and the quiet power of the individual.
					</p>
					<span class="service-label">01 / Fine Art</span>
				</article>

				<!-- Love Stories -->
				<article class="service-card">
					<div class="service-img-wrap">
						<Image
							src="/images/home/what-i-do-1.jpg"
							alt="Couple sharing an intimate moment by a garden pond"
							class="service-img"
							width={800}
							height={1000}
							widths={[400, 800]}
							sizes="(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 33vw"
							layout="none"
						/>
					</div>
					<h3 class="service-title">Love Stories</h3>
					<p class="service-desc">
						Unscripted moments between two souls. We document the chemistry
						that words cannot define.
					</p>
					<span class="service-label">02 / Narrative</span>
				</article>

				<!-- Weddings -->
				<article class="service-card">
					<div class="service-img-wrap">
						<Image
							src="/images/home/what-i-do-2.jpg"
							alt="Bride and groom embracing in a grand hall"
							class="service-img"
							width={800}
							height={1000}
							widths={[400, 800]}
							sizes="(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 33vw"
							layout="none"
						/>
					</div>
					<h3 class="service-title">Weddings</h3>
					<p class="service-desc">
						Full-day cinematic coverage. A timeless visual archive of your most
						significant celebration.
					</p>
					<span class="service-label">03 / Archive</span>
				</article>
			</div>
		</div>
	</section>

	<!-- ─── CTA ──────────────────────────────────────────── -->
	<section class="cta">
		<div class="cta-bg">
			<Image
				src="/images/home/let-document-your-story.jpg"
				alt="Behind the scenes — photographer directing a couple with veil"
				class="cta-img"
				width={1920}
				height={1080}
				widths={[640, 1280, 1920]}
				sizes="100vw"
				layout="none"
			/>
		</div>
		<div class="cta-content">
			<h2 class="cta-heading">Let's document your story.</h2>
			<div class="cta-actions">
				<a href="/contact" class="btn-primary">Book a Consultation</a>
				<a href="/portfolio" class="btn-secondary">View Galleries</a>
			</div>
		</div>
	</section>

</Base>

<style>
	/* ─── Hero ─────────────────────────────────────────── */
	.hero {
		position: relative;
		height: 100svh;
		min-height: 600px;
		display: flex;
		align-items: center;
		justify-content: center;
		overflow: hidden;
	}

	.hero-bg {
		position: absolute;
		inset: 0;
		z-index: 0;
	}

	.hero-img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		filter: grayscale(1) brightness(0.45);
	}

	.hero-content {
		position: relative;
		z-index: 1;
		text-align: center;
		padding: 0 1.5rem;
		max-width: 72rem;
	}

	.hero-title {
		font-family: var(--font-headline);
		font-weight: 200;
		font-size: clamp(2rem, 6vw, 5rem);
		line-height: 1.1;
		letter-spacing: -0.02em;
		color: #ffffff;
	}

	.hero-sub {
		font-family: var(--font-body);
		font-size: 0.7rem;
		text-transform: uppercase;
		letter-spacing: 0.4em;
		color: rgba(255, 255, 255, 0.5);
		margin-top: 2rem;
	}

	/* Decorative 1px line — bottom left */
	.hero-scrubber-deco {
		position: absolute;
		bottom: 0;
		left: 0;
		width: 33%;
		height: 1px;
		background: #ffffff;
		z-index: 1;
	}

	/* ─── About ────────────────────────────────────────── */
	.about {
		background: var(--color-surface);
		padding: 6rem 3rem;
	}

	.about-inner {
		max-width: var(--max-width);
		margin: 0 auto;
		display: grid;
		grid-template-columns: 5fr 7fr;
		gap: 6rem;
		align-items: center;
	}

	.about-image-wrap {
		aspect-ratio: 3 / 4;
		overflow: hidden;
	}

	.about-img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.about-caption {
		font-family: var(--font-body);
		font-size: 0.625rem;
		text-transform: uppercase;
		letter-spacing: 0.15em;
		color: var(--color-outline);
		margin-top: 1rem;
		text-align: right;
	}

	.about-text-col {
		display: flex;
		flex-direction: column;
		justify-content: center;
	}

	.about-eyebrow {
		font-family: var(--font-body);
		font-size: 0.7rem;
		text-transform: uppercase;
		letter-spacing: 0.3em;
		color: var(--color-outline);
		margin-bottom: 2rem;
	}

	.about-heading {
		font-family: var(--font-headline);
		font-weight: 400;
		font-size: clamp(1.75rem, 3.5vw, 3.5rem);
		line-height: 1.1;
		color: var(--color-on-surface);
		margin-bottom: 3rem;
	}

	.about-body {
		max-width: 50ch;
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.about-body p {
		font-family: var(--font-body);
		font-size: 1.1rem;
		font-weight: 300;
		line-height: 1.75;
		color: var(--color-on-surface-variant);
	}

	.about-cta {
		display: inline-flex;
		align-items: center;
		gap: 1rem;
		margin-top: 4rem;
		padding-bottom: 0.5rem;
		border-bottom: 1px solid rgba(71, 71, 71, 1);
		font-family: var(--font-body);
		font-size: 0.7rem;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: var(--color-on-surface);
		transition: border-color 0.4s ease;
		text-decoration: none;
	}

	.about-cta:hover {
		border-color: var(--color-primary);
	}

	.about-cta-arrow {
		font-size: 1rem;
		transition: transform 0.4s ease;
	}

	.about-cta:hover .about-cta-arrow {
		transform: translateX(0.4rem);
	}

	/* ─── Services ─────────────────────────────────────── */
	.services {
		background: var(--color-surface-container-low);
		padding: 6rem 3rem;
	}

	.services-inner {
		max-width: var(--max-width);
		margin: 0 auto;
	}

	.services-header {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		margin-bottom: 6rem;
		flex-wrap: wrap;
		gap: 1rem;
	}

	.services-heading {
		font-family: var(--font-headline);
		font-weight: 300;
		font-size: clamp(2.5rem, 5vw, 4.5rem);
		color: #ffffff;
		line-height: 1;
	}

	.services-sub {
		font-family: var(--font-body);
		font-size: 0.65rem;
		text-transform: uppercase;
		letter-spacing: 0.2em;
		color: var(--color-outline);
	}

	.services-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1px;
		background: rgba(71, 71, 71, 0.15);
	}

	.service-card {
		background: var(--color-surface);
		padding: 3rem;
		cursor: pointer;
		position: relative;
		transition: background 0.6s ease;
		overflow: hidden;
	}

	/* Top reveal line draws across on hover */
	.service-card::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		width: 0%;
		height: 1px;
		background: #ffffff;
		transition: width 0.6s cubic-bezier(0.16, 1, 0.3, 1);
	}

	.service-card:hover {
		background: var(--color-surface-container-high);
	}

	.service-card:hover::before {
		width: 100%;
	}

	.service-img-wrap {
		aspect-ratio: 4 / 5;
		overflow: hidden;
		margin-bottom: 2rem;
		position: relative;
	}

	/* Dark gradient overlay — fades out on hover for a reveal effect */
	.service-img-wrap::after {
		content: '';
		position: absolute;
		inset: 0;
		background: linear-gradient(to top, rgba(0, 0, 0, 0.45) 0%, transparent 55%);
		opacity: 1;
		transition: opacity 0.7s ease;
		pointer-events: none;
		z-index: 1;
	}

	.service-card:hover .service-img-wrap::after {
		opacity: 0;
	}

	.service-img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		filter: grayscale(1);
		transition:
			transform 0.9s cubic-bezier(0.16, 1, 0.3, 1),
			filter 0.9s ease;
	}

	/* Image: zoom in + reveal colour on hover */
	.service-card:hover .service-img {
		transform: scale(1.07);
		filter: grayscale(0);
	}

	.service-title {
		font-family: var(--font-headline);
		font-weight: 400;
		font-size: 1.875rem;
		color: var(--color-on-surface);
		margin-bottom: 1rem;
		transition: transform 0.45s cubic-bezier(0.16, 1, 0.3, 1), color 0.3s ease;
	}

	.service-card:hover .service-title {
		transform: translateY(-4px);
		color: #ffffff;
	}

	.service-desc {
		font-family: var(--font-body);
		font-size: 0.875rem;
		line-height: 1.65;
		color: var(--color-on-surface-variant);
		margin-bottom: 2rem;
		transition: transform 0.45s cubic-bezier(0.16, 1, 0.3, 1), color 0.3s ease;
	}

	.service-card:hover .service-desc {
		transform: translateY(-3px);
		color: rgba(210, 210, 210, 0.9);
	}

	.service-label {
		font-family: var(--font-body);
		font-size: 0.625rem;
		text-transform: uppercase;
		letter-spacing: 0.18em;
		color: var(--color-outline);
		display: inline-block;
		transition: color 0.3s ease, letter-spacing 0.5s cubic-bezier(0.16, 1, 0.3, 1);
	}

	.service-card:hover .service-label {
		color: #ffffff;
		letter-spacing: 0.28em;
	}

	/* ─── CTA ──────────────────────────────────────────── */
	.cta {
		position: relative;
		min-height: 820px;
		display: flex;
		align-items: center;
		justify-content: center;
		overflow: hidden;
	}

	.cta-bg {
		position: absolute;
		inset: 0;
		z-index: 0;
	}

	.cta-img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		filter: brightness(0.55);
	}

	.cta-content {
		position: relative;
		z-index: 1;
		text-align: center;
		padding: 0 1.5rem;
		max-width: 56rem;
	}

	.cta-heading {
		font-family: var(--font-headline);
		font-weight: 300;
		font-size: clamp(2.5rem, 7vw, 5.5rem);
		line-height: 1.05;
		color: #ffffff;
		margin-bottom: 3rem;
	}

	.cta-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 1.5rem;
		justify-content: center;
		align-items: center;
	}

	.btn-primary {
		display: inline-block;
		background: #ffffff;
		color: #1a1c1c;
		padding: 1.25rem 2.5rem;
		font-family: var(--font-body);
		font-size: 0.65rem;
		text-transform: uppercase;
		letter-spacing: 0.18em;
		font-weight: 500;
		transition: background 0.4s ease, color 0.4s ease;
		text-decoration: none;
	}

	.btn-primary:hover {
		background: var(--color-on-surface);
		color: var(--color-surface);
	}

	.btn-secondary {
		display: inline-block;
		border: 1px solid rgba(255, 255, 255, 0.2);
		color: #ffffff;
		padding: 1.25rem 2.5rem;
		font-family: var(--font-body);
		font-size: 0.65rem;
		text-transform: uppercase;
		letter-spacing: 0.18em;
		font-weight: 500;
		transition: border-color 0.4s ease;
		text-decoration: none;
	}

	.btn-secondary:hover {
		border-color: #ffffff;
	}

	/* ─── Responsive ───────────────────────────────────── */
	@media (max-width: 1024px) {
		.about {
			padding: 5rem 2rem;
		}

		.about-inner {
			grid-template-columns: 1fr 1fr;
			gap: 4rem;
		}

		.services {
			padding: 5rem 2rem;
		}

		.service-card {
			padding: 2rem;
		}
	}

	@media (max-width: 768px) {
		.about-inner {
			grid-template-columns: 1fr;
			gap: 3rem;
		}

		.about-image-wrap {
			aspect-ratio: 4 / 3;
		}

		.services-grid {
			grid-template-columns: 1fr;
		}

		.services-header {
			margin-bottom: 3rem;
		}
	}

	@media (max-width: 480px) {
		.about,
		.services {
			padding: 4rem 1.5rem;
		}

		.cta-actions {
			flex-direction: column;
			width: 100%;
		}

		.btn-primary,
		.btn-secondary {
			width: 100%;
			text-align: center;
		}
	}
</style>
