---
import Base from "../../layouts/Base.astro";
---

<Base title="Huy & Trang — Soft Light" description="A tender study of love in soft light — quiet moments and gentle touches captured between two souls.">
	<main class="portfolio-main">

		<header class="portfolio-header">
			<a href="/portfolios" class="back-link">
				<span class="material-symbols-outlined">arrow_back</span>
				<span>Back to Portfolios</span>
			</a>
			<h1 class="portfolio-title">Huy &amp; Trang<br/>Soft Light</h1>
			<p class="portfolio-desc">
				A tender study of love in soft light — quiet moments and gentle touches
				captured between two souls on the edge of forever.
			</p>
		</header>

		<section class="gallery">

			<!-- Row 1: Offset vertical pair -->
			<div class="row row-pair-offset">
				<div class="plate col-5">
					<div class="img-wrap ratio-2-3">
						<img src="/images/t-c-prewedding/image-1.jpg" alt="Plate 001" class="gallery-img" loading="lazy" />
					</div>
					<div class="plate-meta">
						<span class="plate-num">Plate No. 001</span>
						<span class="plate-caption">First Light</span>
					</div>
				</div>
				<div class="plate col-6 offset-top">
					<div class="img-wrap ratio-square">
						<img src="/images/t-c-prewedding/image-2.jpg" alt="Plate 002" class="gallery-img" loading="lazy" />
					</div>
					<div class="plate-meta">
						<span class="plate-num">Plate No. 002</span>
						<span class="plate-caption">Still Together</span>
					</div>
				</div>
			</div>

			<!-- Row 2: Wide cinematic -->
			<div class="row row-wide">
				<div class="img-wrap ratio-21-9">
					<img src="/images/t-c-prewedding/image-3.jpg" alt="Plate 003" class="gallery-img" loading="lazy" />
				</div>
				<div class="wide-meta">
					<div>
						<h3 class="wide-title">Between the Hours</h3>
						<p class="wide-desc">The golden threshold where day surrenders to evening, and two people find each other again.</p>
					</div>
					<span class="plate-num">Plate No. 003 / Dusk</span>
				</div>
			</div>

			<!-- Row 3: Balanced trio -->
			<div class="row row-trio">
				<div class="plate">
					<div class="img-wrap ratio-4-5">
						<img src="/images/t-c-prewedding/image-4.jpg" alt="Plate 004" class="gallery-img" loading="lazy" />
					</div>
					<div class="plate-solo"><span class="plate-num">Plate No. 004</span></div>
				</div>
				<div class="plate trio-mid">
					<div class="img-wrap ratio-4-5">
						<img src="/images/t-c-prewedding/image-5.jpg" alt="Plate 005" class="gallery-img" loading="lazy" style="object-position: top" />
					</div>
					<div class="plate-solo"><span class="plate-num">Plate No. 005</span></div>
				</div>
				<div class="plate">
					<div class="img-wrap ratio-4-5">
						<img src="/images/t-c-prewedding/image-6.jpg" alt="Plate 006" class="gallery-img" loading="lazy" />
					</div>
					<div class="plate-solo"><span class="plate-num">Plate No. 006</span></div>
				</div>
			</div>

			<!-- Row 4: Horizontal + vertical aligned bottom -->
			<div class="row row-pair-bottom">
				<div class="plate col-7">
					<div class="img-wrap ratio-16-10">
						<img src="/images/t-c-prewedding/image-7.jpg" alt="Plate 007" class="gallery-img" loading="lazy" />
					</div>
					<div class="plate-meta">
						<span class="plate-num">Plate No. 007 / The Frame</span>
						<span class="plate-caption">A Borrowed Moment</span>
					</div>
				</div>
				<div class="plate col-4">
					<div class="img-wrap ratio-3-4">
						<img src="/images/t-c-prewedding/image-8.jpg" alt="Plate 008" class="gallery-img" loading="lazy" />
					</div>
					<div class="plate-solo"><span class="plate-num">Plate No. 008 / Presence</span></div>
				</div>
			</div>

			<!-- Row 5: Dynamic offset pair -->
			<div class="row row-offset-pair">
				<div class="plate offset-left">
					<div class="img-wrap ratio-square">
						<img src="/images/t-c-prewedding/image-9.jpg" alt="Plate 009" class="gallery-img" loading="lazy" />
					</div>
					<div class="plate-solo"><span class="plate-num">Plate No. 009</span></div>
				</div>
				<div class="plate offset-down">
					<div class="img-wrap ratio-3-2">
						<img src="/images/t-c-prewedding/image-10.jpg" alt="Plate 010" class="gallery-img" loading="lazy" />
					</div>
					<div class="plate-solo"><span class="plate-num">Plate No. 010</span></div>
				</div>
			</div>

			<!-- Row 6: Final full-width cinematic -->
			<div class="row row-final">
				<div class="final-plate">
					<div class="img-wrap">
						<img src="/images/t-c-prewedding/image-11.jpg" alt="Plate 011" class="gallery-img gallery-img--natural" loading="lazy" />
					</div>
					<div class="final-meta">
						<span class="plate-num">Plate No. 011 / Stillness</span>
						<h2 class="final-title">The Softest Promise</h2>
					</div>
				</div>
			</div>

		</section>

		<div class="next-project">
			<span class="next-label">Next Project</span>
			<a href="/portfolios/minh-linh-evermore" class="next-link">
				<span class="next-name">Minh &amp; Linh — Evermore</span>
				<span class="material-symbols-outlined">east</span>
			</a>
		</div>

	</main>
</Base>

<style>
	.portfolio-main {
		padding-top: 8rem;
		padding-bottom: 10rem;
		max-width: 1600px;
		margin: 0 auto;
		padding-left: 1.5rem;
		padding-right: 1.5rem;
	}

	@media (min-width: 768px) {
		.portfolio-main {
			padding-left: 3rem;
			padding-right: 3rem;
		}
	}

	/* Header */
	.portfolio-header {
		margin-bottom: 6rem;
		max-width: 56rem;
	}

	@media (min-width: 768px) {
		.portfolio-header { margin-bottom: 10rem; }
	}

	.back-link {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		font-family: "Manrope", sans-serif;
		font-size: 0.7rem;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.35);
		text-decoration: none;
		margin-bottom: 3rem;
		transition: color 0.4s ease;
	}

	.back-link:hover { color: #ffffff; }
	.back-link .material-symbols-outlined { font-size: 1rem; }

	.portfolio-title {
		font-family: "Newsreader", serif;
		font-style: italic;
		font-size: clamp(3rem, 8vw, 6rem);
		font-weight: 300;
		line-height: 1.05;
		letter-spacing: -0.02em;
		color: #ffffff;
		margin: 0 0 2rem;
	}

	.portfolio-desc {
		font-family: "Manrope", sans-serif;
		font-weight: 300;
		font-size: 1.1rem;
		line-height: 1.75;
		color: rgba(255, 255, 255, 0.4);
		max-width: 40rem;
		margin: 0;
	}

	/* Gallery */
	.gallery {
		display: flex;
		flex-direction: column;
		gap: 5rem;
	}

	@media (min-width: 768px) {
		.gallery { gap: 12rem; }
	}

	/* Image wrappers */
	.img-wrap {
		overflow: hidden;
		background: #111;
	}

	.gallery-img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		filter: grayscale(100%);
		transition: filter 1.2s cubic-bezier(0.22, 1, 0.36, 1),
		            transform 1.2s cubic-bezier(0.22, 1, 0.36, 1);
	}

	.gallery-img--natural { height: auto; }

	.img-wrap:hover .gallery-img {
		filter: grayscale(0%);
		transform: scale(1.02);
	}

	/* Aspect ratios */
	.ratio-2-3    { aspect-ratio: 2 / 3; }
	.ratio-square { aspect-ratio: 1 / 1; }
	.ratio-21-9   { aspect-ratio: 21 / 9; }
	.ratio-4-5    { aspect-ratio: 4 / 5; }
	.ratio-16-10  { aspect-ratio: 16 / 10; }
	.ratio-3-4    { aspect-ratio: 3 / 4; }
	.ratio-3-2    { aspect-ratio: 3 / 2; }

	/* Labels */
	.plate-meta {
		margin-top: 2rem;
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		border-bottom: 1px solid rgba(255, 255, 255, 0.07);
		padding-bottom: 0.5rem;
	}

	.plate-num {
		font-family: "Manrope", sans-serif;
		font-size: 0.625rem;
		letter-spacing: 0.3em;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.3);
	}

	.plate-caption {
		font-family: "Newsreader", serif;
		font-style: italic;
		font-size: 0.8rem;
		color: rgba(255, 255, 255, 0.4);
	}

	.plate-solo { margin-top: 1rem; }

	/* Row 1 */
	.row-pair-offset {
		display: grid;
		grid-template-columns: 1fr;
		gap: 3rem;
	}

	@media (min-width: 768px) {
		.row-pair-offset {
			grid-template-columns: repeat(12, 1fr);
			gap: 3rem;
			align-items: start;
		}
		.row-pair-offset .col-5 { grid-column: span 5; }
		.row-pair-offset .col-6 { grid-column: 7 / span 6; }
		.offset-top { margin-top: 5rem; }
	}

	/* Row 2 */
	.row-wide {
		max-width: 72rem;
		margin: 0 auto;
		width: 100%;
	}

	.wide-meta {
		margin-top: 2rem;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	@media (min-width: 768px) {
		.wide-meta {
			flex-direction: row;
			justify-content: space-between;
			align-items: flex-end;
		}
	}

	.wide-title {
		font-family: "Newsreader", serif;
		font-style: italic;
		font-size: 1.5rem;
		color: #ffffff;
		margin: 0 0 0.5rem;
	}

	.wide-desc {
		font-family: "Manrope", sans-serif;
		font-size: 0.875rem;
		line-height: 1.6;
		color: rgba(255, 255, 255, 0.35);
		max-width: 28rem;
		margin: 0;
	}

	/* Row 3 */
	.row-trio {
		display: grid;
		grid-template-columns: 1fr;
		gap: 2rem;
	}

	@media (min-width: 768px) {
		.row-trio { grid-template-columns: repeat(3, 1fr); }
		.trio-mid { margin-top: 4rem; }
	}

	/* Row 4 */
	.row-pair-bottom {
		display: grid;
		grid-template-columns: 1fr;
		gap: 3rem;
	}

	@media (min-width: 768px) {
		.row-pair-bottom {
			grid-template-columns: repeat(12, 1fr);
			gap: 3rem;
			align-items: end;
		}
		.row-pair-bottom .col-7 { grid-column: span 7; }
		.row-pair-bottom .col-4 { grid-column: 9 / span 4; }
	}

	/* Row 5 */
	.row-offset-pair {
		display: grid;
		grid-template-columns: 1fr;
		gap: 3rem;
	}

	@media (min-width: 768px) {
		.row-offset-pair { grid-template-columns: repeat(12, 1fr); gap: 3rem; }
		.offset-left { grid-column: 2 / span 4; }
		.offset-down { grid-column: 7 / span 6; margin-top: 8rem; }
	}

	/* Row 6 */
	.row-final {
		display: flex;
		justify-content: center;
	}

	.final-plate {
		max-width: 56rem;
		width: 100%;
	}

	.final-meta {
		margin-top: 3rem;
		text-align: center;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1rem;
	}

	.final-title {
		font-family: "Newsreader", serif;
		font-style: italic;
		font-size: clamp(2.5rem, 6vw, 4.5rem);
		font-weight: 300;
		color: #ffffff;
		line-height: 1.1;
		margin: 0;
	}

	/* Next project */
	.next-project {
		margin-top: 16rem;
		padding-top: 3rem;
		border-top: 1px solid rgba(255, 255, 255, 0.06);
		display: flex;
		justify-content: space-between;
		align-items: center;
		flex-wrap: wrap;
		gap: 1.5rem;
	}

	.next-label {
		font-family: "Newsreader", serif;
		font-style: italic;
		font-size: 1.2rem;
		color: rgba(255, 255, 255, 0.35);
	}

	.next-link {
		display: flex;
		align-items: center;
		gap: 1rem;
		text-decoration: none;
		color: #ffffff;
	}

	.next-name {
		font-family: "Newsreader", serif;
		font-size: clamp(1.5rem, 4vw, 2.5rem);
		font-weight: 300;
		transition: font-style 0.3s ease;
	}

	.next-link:hover .next-name { font-style: italic; }
	.next-link .material-symbols-outlined { font-size: 2rem; }
</style>
