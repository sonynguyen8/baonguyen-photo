---
import Base from "../../layouts/Base.astro";

const works = [
	{
		title: "Minh & Linh - Prewedding",
		category: "Weddings",
		year: "01-2025",
		italic: true,
		url: "/minh-linh-evermore",
		src: "/images/s-s-prewedding/image-11.jpg",
	},
	{
		title: "Huy & Trang - Save the day",
		category: "Portraits",
		year: "03-2025",
		italic: false,
		url: "/huy-trang-softlight",
		src: "/images/t-c-prewedding/image-2.jpg",
	},
	{
		title: "Khang & Vy - Prewedding",
		category: "Love Stories",
		year: "06-2025",
		italic: true,
		url: "/khang-vy-golden-hour",
		src: "/images/s-s-prewedding/image-8.jpg",
	},
	{
		title: "Tuấn & Ngọc - Save the day",
		category: "Portraits",
		year: "09-2025",
		italic: false,
		url: "/tuan-ngoc-sweet-moment",
		src: "/images/coming-soon.jpg",
	},
	{
		title: "Đức & Hân - Prewedding",
		category: "Weddings",
		year: "11-2025",
		italic: false,
		url: "/duc-han-quiet-love",
		src: "/images/coming-soon.jpg",
	},
	{
		title: "Phúc & Mai - Save the day",
		category: "Love Stories",
		year: "01-2026",
		italic: true,
		url: "/phuc-mai-first-light",
		src: "/images/coming-soon.jpg",
	},
	{
		title: "Nam & Thảo - Prewedding",
		category: "Weddings",
		year: "02-2026",
		italic: false,
		url: "/nam-thao-timeless",
		src: "/images/coming-soon.jpg",
	},
	{
		title: "Quân & Linh - Save the day",
		category: "Portraits",
		year: "03-2026",
		italic: false,
		url: "/quan-linh-daydream",
		src: "/images/coming-soon.jpg",
	},
	{
		title: "Hoàng & Vy - Prewedding",
		category: "Love Stories",
		year: "04-2026",
		italic: true,
		url: "/hoang-vy-in-bloom",
		src: "/images/coming-soon.jpg",
	},
];

const filters = ["All", "Portraits", "Love Stories", "Weddings"];
---

<Base title="Selected Works" description="A curated collection of cinematic noir photography — portraits, love stories, and wedding coverage.">

	<div class="works-page">

		<!-- ─── Page Header ──────────────────────────────── -->
		<header class="works-header">
			<div class="works-header-inner">
				<h1 class="works-title">Selected Works</h1>

				<!-- Filter pills -->
				<div class="works-filters" id="works-filters" role="tablist" aria-label="Filter works by category">
					{filters.map((f, i) => (
						<button
							role="tab"
							aria-selected={i === 0}
							data-filter={f}
							class:list={["filter-pill", { active: i === 0 }]}
						>
							{f}
						</button>
					))}
				</div>
			</div>
		</header>

		<!-- ─── Scrubber rule ────────────────────────────── -->
		<div class="works-rule" aria-hidden="true">
			<div class="works-rule-fill"></div>
		</div>

		<!-- ─── Gallery Grid ─────────────────────────────── -->
		<section class="gallery" aria-label="Portfolio gallery">
			<div class="gallery-grid" id="gallery-grid">
				{works.map((work) => (
					<article
						class="gallery-item"
						data-category={work.category}
					>
						<a href={`/portfolios${work.url}`} class="gallery-link">
							<div class="gallery-img-wrap">
								<img
									src={work.src}
									alt={work.title}
									class="gallery-img"
									loading="lazy"
								/>
							</div>
							<div class="gallery-meta">
								<h3 class:list={["gallery-title", { italic: work.italic }]}>
									{work.title}
								</h3>
								<span class="gallery-label">{work.category}</span>
							</div>
						</a>
					</article>
				))}
			</div>
		</section>

		<!-- ─── CTA ──────────────────────────────────────── -->
		<section class="works-cta">
			<div class="works-cta-inner">
				<h2 class="works-cta-heading">Capture your own story</h2>
				<a href="/contact" class="works-cta-btn">Book a Session</a>
			</div>
		</section>

	</div>

</Base>

<script>
	const filterBar = document.getElementById("works-filters")!;
	const grid = document.getElementById("gallery-grid")!;

	filterBar.addEventListener("click", (e) => {
		const btn = (e.target as HTMLElement).closest<HTMLButtonElement>("[data-filter]");
		if (!btn) return;

		const filter = btn.dataset.filter!;

		// Update pill states
		filterBar.querySelectorAll<HTMLButtonElement>(".filter-pill").forEach((p) => {
			const isActive = p === btn;
			p.classList.toggle("active", isActive);
			p.setAttribute("aria-selected", String(isActive));
		});

		// Show / hide items
		grid.querySelectorAll<HTMLElement>(".gallery-item").forEach((item) => {
			const match = filter === "All" || item.dataset.category === filter;
			item.style.display = match ? "" : "none";
		});
	});
</script>

<style>
	.works-page {
		padding-top: 7rem; /* clear fixed nav */
		padding-bottom: 0;
	}

	/* ─── Header ────────────────────────────────────────── */
	.works-header {
		padding: 3rem 3rem 0;
	}

	.works-header-inner {
		max-width: var(--max-width);
		margin: 0 auto;
	}

	.works-title {
		font-family: var(--font-headline);
		font-weight: 300;
		font-size: clamp(3rem, 7vw, 6rem);
		letter-spacing: -0.02em;
		color: var(--color-primary);
		line-height: 1;
		margin-bottom: 3rem;
	}

	/* Filter pills */
	.works-filters {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		border-top: 1px solid rgba(71, 71, 71, 0.2);
		padding-top: 2rem;
	}

	.filter-pill {
		font-family: var(--font-body);
		font-size: 0.625rem;
		text-transform: uppercase;
		letter-spacing: 0.18em;
		font-weight: 500;
		padding: 0.5rem 1.5rem;
		border-radius: 9999px;
		border: 1px solid rgba(145, 145, 145, 0.3);
		background: transparent;
		color: var(--color-outline);
		cursor: pointer;
		transition: border-color 0.3s ease, color 0.3s ease;
	}

	.filter-pill:hover {
		border-color: var(--color-primary);
		color: var(--color-primary);
	}

	.filter-pill.active {
		border-color: var(--color-primary);
		color: var(--color-primary);
	}

	/* ─── Rule ──────────────────────────────────────────── */
	.works-rule {
		width: 100%;
		height: 1px;
		background: rgba(255, 255, 255, 0.05);
		margin: 5rem 0;
	}

	.works-rule-fill {
		height: 1px;
		width: 45%;
		background: #ffffff;
	}

	/* ─── Gallery ───────────────────────────────────────── */
	.gallery {
		padding: 0 3rem;
	}

	.gallery-link {
		display: flex;
		flex-direction: column;
		text-decoration: none;
		color: inherit;
	}

	.gallery-grid {
		max-width: var(--max-width);
		margin: 0 auto;
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2rem;
	}

	.gallery-item {
		display: flex;
		flex-direction: column;
	}

	.gallery-img-wrap {
		overflow: hidden;
		background: var(--color-surface-container-lowest);
		aspect-ratio: 4 / 5;
	}

	.gallery-img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		filter: grayscale(1);
		transition: filter 0.7s ease, transform 0.7s ease;
		display: block;
	}

	.gallery-item:hover .gallery-img {
		filter: grayscale(0);
		transform: scale(1.03);
	}

	.gallery-meta {
		margin-top: 1rem;
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 0.5rem;
	}

	.gallery-title {
		font-family: var(--font-headline);
		font-weight: 300;
		font-size: 1.2rem;
		color: var(--color-on-surface);
		line-height: 1.2;
	}

	.gallery-title.italic {
		font-style: italic;
	}

	.gallery-label {
		font-family: var(--font-body);
		font-size: 0.5rem;
		text-transform: uppercase;
		letter-spacing: 0.18em;
		color: var(--color-outline);
		white-space: nowrap;
		flex-shrink: 0;
	}

	/* ─── CTA ───────────────────────────────────────────── */
	.works-cta {
		padding: 10rem 3rem;
		text-align: center;
	}

	.works-cta-inner {
		max-width: 42rem;
		margin: 0 auto;
	}

	.works-cta-heading {
		font-family: var(--font-headline);
		font-style: italic;
		font-weight: 300;
		font-size: clamp(2rem, 4.5vw, 3.25rem);
		color: var(--color-on-surface);
		margin-bottom: 2.5rem;
		line-height: 1.1;
	}

	.works-cta-btn {
		display: inline-block;
		background: var(--color-primary);
		color: var(--color-on-primary);
		padding: 1.25rem 3rem;
		font-family: var(--font-body);
		font-size: 0.65rem;
		text-transform: uppercase;
		letter-spacing: 0.18em;
		font-weight: 500;
		text-decoration: none;
		transition: opacity 0.4s ease;
	}

	.works-cta-btn:hover {
		opacity: 0.85;
	}

	/* ─── Responsive ────────────────────────────────────── */
	@media (max-width: 1024px) {
		.works-header,
		.gallery {
			padding-left: 2rem;
			padding-right: 2rem;
		}

		.gallery-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 640px) {
		.works-header,
		.gallery,
		.works-cta {
			padding-left: 1.5rem;
			padding-right: 1.5rem;
		}

		.works-title {
			margin-bottom: 2rem;
		}

		.gallery-grid {
			grid-template-columns: 1fr;
			gap: 3rem;
		}

		.works-cta {
			padding-top: 6rem;
			padding-bottom: 6rem;
		}
	}
</style>
